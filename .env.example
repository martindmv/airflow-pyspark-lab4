# Copy this file to ".env" before running docker compose.
#   cp .env.example .env       (Linux/Mac)
#   copy .env.example .env     (Windows)

# Local user that owns mounted volumes.
# - On Linux/Mac, set AIRFLOW_UID=$(id -u).
# - On Windows (Docker Desktop), leave it at 50000.
AIRFLOW_UID=50000

# Project root.
AIRFLOW_PROJ_DIR=.

# Port the Airflow Web UI is exposed on locally.
AIRFLOW_UI_PORT=8080

# Default admin user.
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
